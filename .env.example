# =========================
# Core
# =========================
NODE_ENV=development
PORT=5000
JWT_SECRET=replace-with-at-least-32-char-secret
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=replace-with-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:3000
DEV_ROUTE_SECRET=replace-with-dev-route-secret

# =========================
# Database
# =========================
MONGO_URI=mongodb://127.0.0.1:27017/kha_backend_dev

# =========================
# Redis
# =========================
REDIS_URL=redis://127.0.0.1:6379
REDIS_DISABLED=false
ENABLE_SOCKET_IO_REDIS=false

# =========================
# Payment (Razorpay)
# =========================
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=razorpay_webhook_secret_here
ALLOW_DEV_PAYMENT=false
ALLOW_RECONCILE_FALLBACK=false
PAYMENT_RECONCILE_CRON=*/3 * * * *

# =========================
# Email (SMTP)
# =========================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
SMTP_SECURE=false
ADMIN_EMAIL_FROM=no-reply@example.com
MAIL_USER=
MAIL_PASS=

# =========================
# Storage
# =========================
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=aws_access_key_id
AWS_SECRET_ACCESS_KEY=aws_secret_access_key
AWS_ACCESS_KEY=
AWS_SECRET=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-s3-bucket
S3_BUCKET=
AWS_S3_PUBLIC_URL_BASE=
SIGNED_URL_EXPIRY=600
REQUIRE_SECURE_DOCUMENTS=true

CLOUDINARY_CLOUD_NAME=cloudinary-cloud-name
CLOUDINARY_API_KEY=cloudinary-api-key
CLOUDINARY_API_SECRET=cloudinary-api-secret

# =========================
# Notifications
# =========================
FCM_SERVER_KEY=fcm-server-key
ENABLE_NOTIFICATIONS=true
ENABLE_EMAILS=true
ENABLE_FIREBASE_FCM=false
FIREBASE_SERVICE_ACCOUNT_PATH=
NOTIFICATION_RETRY_RETENTION_DAYS=14

# =========================
# External Services / Messaging
# =========================
MSG91_AUTH_KEY=msg91-auth-key
MSG91_TEMPLATE_ID=msg91-template-id
GOOGLE_MAPS_API_KEY=google-maps-api-key
SUPPORT_PHONE=+910000000000
SUPPORT_MESSAGE=Contact support for help

# =========================
# Logging / Monitoring
# =========================
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
ENABLE_METRICS=true
ENABLE_SECURITY_HARDENING=true

# =========================
# Rate Limit
# =========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CRON_LOCK_TTL_MS=55000

# =========================
# Request / File Limits
# =========================
REQUEST_SIZE_LIMIT=10kb
MAX_FILE_SIZE=5242880
